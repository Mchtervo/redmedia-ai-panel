# Supabase (bkz. docs/DATABASE.md, docs/SECURITY.md)
# NEXT_PUBLIC_* değişkenleri istemciye açıktır, sır içermez.
# SUPABASE_SERVICE_ROLE_KEY yalnızca sunucu tarafında kullanılır, asla istemciye gönderilmez.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ChatPlace webhook kimlik doğrulama (yalnızca sunucu tarafı, asla istemciye gitmez)
# HMAC: x-chatplace-signature (CHATPLACE_WEBHOOK_SECRET ile)
# Token: x-chatplace-token (CHATPLACE_WEBHOOK_TOKEN ile; External API Request için)
# İkisinden biri geçerliyse istek kabul edilir.
CHATPLACE_WEBHOOK_SECRET=
CHATPLACE_WEBHOOK_TOKEN=

# OpenAI basit asistan (yalnızca sunucu tarafı; asla NEXT_PUBLIC_ yapma)
# AI_AUTO_REPLY_ENABLED=false ile otomatik cevap kapatılır.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_AUTO_REPLY_ENABLED=true
