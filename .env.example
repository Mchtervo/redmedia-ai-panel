# =============================================================
# Redmedia AI Panel — environment şablonu
# Gerçek değerleri YALNIZCA .env.local dosyasına yazın (git'e gitmez).
# Sır değerleri asla NEXT_PUBLIC_ öneki ile tanımlanmaz.
# Doğrulama: src/lib/env.ts (startup'ta zorunlu alanlar denetlenir).
# Ayrıntı: docs/45_ENVIRONMENT_CONFIGURATION.md
# =============================================================

# --- Supabase (ZORUNLU — uygulama bunlarsız başlamaz) ---
# NEXT_PUBLIC_* değişkenleri istemciye açıktır, sır içermez.
# SUPABASE_SERVICE_ROLE_KEY yalnızca sunucu tarafında kullanılır.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI / AI Model Router (docs/41) ---
# OPENAI_API_KEY boşsa AI özellikleri kendini kapatır (uygulama çalışır).
OPENAI_API_KEY=
# Görev katmanı → model eşlemesi (hepsi opsiyonel; boş katman DEFAULT'a,
# DEFAULT da boşsa güvenli sabit varsayılana düşer):
# FAST      → yorum / sınıflandırma → gpt-5-mini (veya yetki varsa gpt-5.6-luna)
# DEFAULT   → DM satış + CRM / rezervasyon / öğrenme → gpt-5.6-terra
# REASONING → CEO / marketing strateji → gpt-5.6-terra (gerekirse sol)
# COMPLEX   → derin teknik analiz → gpt-5.6-sol
# EMBEDDING → RAG → text-embedding-3-small
# Not: çıplak "gpt-5.6" = Sol. luna bazı hesaplarda 401 verebilir.
OPENAI_MODEL_FAST=gpt-5-mini
# dm_reply bu katmanı kullanır. Lab↔Production parity için Production'da da aynı değeri set edin.
OPENAI_MODEL_DEFAULT=gpt-5.6-terra
OPENAI_MODEL_REASONING=gpt-5.6-terra
OPENAI_MODEL_COMPLEX=gpt-5.6-sol
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
# Canlı Instagram/DM auto-reply — VARSAyILAN KAPALI.
# Açmak için açıkça true: AI_REPLY_ENABLED=true (veya AI_AUTO_REPLY_ENABLED=true)
# + OpenAI + panel AI_DM_ASSISTANT / AI_MASTER.
AI_REPLY_ENABLED=false
AI_AUTO_REPLY_ENABLED=false
# Conversation Critic (AI Judge): cevap üret → eleştir → gerekirse rewrite.
# false/0/off = kapalı. Varsayılan: açık (OpenAI yapılandırılmışken).
AI_CONVERSATION_CRITIC_ENABLED=
# Multi Judge: satış + psikolog + müşteri (3 hakem ortalaması). Varsayılan: açık.
AI_MULTI_JUDGE_ENABLED=
# Conversation Strategist: LLM öncesi tek hamle kararı. Varsayılan: açık.
AI_CONVERSATION_STRATEGIST_ENABLED=
# DM cevap A/B (A=mevcut, B=örnek/güven önce). Varsayılan: açık.
AI_REPLY_AB_ENABLED=

# --- DEPRECATED (yalnızca geçiş dönemi; yenisine taşıyın) ---
# OPENAI_MODEL          → OPENAI_MODEL_DEFAULT
# OPENAI_MODEL_BALANCED → OPENAI_MODEL_DEFAULT
# OPENAI_MODEL_VISION   → görsel görevler DEFAULT katmanını kullanır

# --- ChatPlace MCP (salt okuma senkronizasyonu, docs/44) ---
# İkisi birlikte tanımlanmalı; yalnızca sunucu tarafında okunur.
CHATPLACE_API_KEY=
CHATPLACE_MCP_URL=https://mcp.chatplace.io/mcp

# --- ChatPlace webhook (OPSİYONEL — yalnızca inbound webhook için) ---
# MCP salt okuma senkronizasyonu için GEREKMEZ. Webhook kullanılacaksa:
# HMAC: x-chatplace-signature (CHATPLACE_WEBHOOK_SECRET ile) VEYA
# Token: x-chatplace-token (CHATPLACE_WEBHOOK_TOKEN ile).
# Token'ı sahibi üretir (örn. `openssl rand -hex 32`) ve aynı değeri
# ChatPlace External Request header'ına yazar.
CHATPLACE_WEBHOOK_SECRET=
CHATPLACE_WEBHOOK_TOKEN=

# --- Cron (Bearer CRON_SECRET; boşsa cron uçları tüm istekleri reddeder) ---
CRON_SECRET=

# --- Dekont yüksek güven otomatik onay (varsayılan kapalı) ---
AUTO_CONFIRM_HIGH_CONFIDENCE_RECEIPTS=

# --- Meta / Marketing Director (yalnızca sunucu; asla NEXT_PUBLIC_ yapma) ---
META_APP_ID=
META_APP_SECRET=
# META_ACCESS_TOKEN kullanılmaz — token OAuth ile meta_oauth_tokens tablosuna yazılır
META_BUSINESS_ID=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_INSTAGRAM_ACCOUNT_ID=
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Events Manager → Olayları Test Et kodu (yoksa CAPI olay gönderilmez)
META_CAPI_TEST_EVENT_CODE=
# CAPI test PageView event_source_url (SITE_URL de kabul edilir)
META_CAPI_EVENT_SOURCE_URL=
SITE_URL=
META_GRAPH_API_VERSION=
META_OAUTH_REDIRECT_URI=
META_OAUTH_STATE_SECRET=
